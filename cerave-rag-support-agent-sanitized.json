    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\n\nconst message = body.Message || body.message || body.question || \"\";\nconst customerName = body.CustomerName || body.name || \"Customer\";\n\nif (!message) {\n  throw new Error(\"Customer message is missing. Send Message or message in the request body.\");\n}\n\nreturn [\n  {\n    json: {\n      CustomerName: customerName,\n      Message: message,\n      Email: body.Email || body.email || \"\",\n      Source: \"Webhook\",\n      CreatedAt: new Date().toISOString()\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1040,
        272
      ],
      "id": "2a4adb9c-5207-436b-ae15-29cbfc3f435a",
      "name": "Clean Input"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a demo AI customer support assistant for CeraVe FAQ questions.\n\nYou are not official CeraVe support.\n\nYour job:\n- Answer CeraVe FAQ questions using the uploaded CeraVe FAQ PDF.\n- Help with questions about where to buy, product authenticity, coupons, samples, ceramides, MVE technology, fragrance-free products, non-comedogenic products, and general product information.\n- Classify the customer message.\n- Decide if human support is needed.\n\nTool usage rule:\nUse the cerave_faq_knowledge_base tool only for FAQ, product, ingredient, where-to-buy, coupons, samples, ceramides, MVE technology, fragrance-free, and non-comedogenic questions.\n\nSafety exception:\nIf the customer message mentions burning, swelling, allergic reaction, severe irritation, infection, eczema flare, psoriasis, pain, rash, or any serious skin concern, do not use the tool. Immediately return a safety response, recommend consulting a dermatologist or healthcare professional, and set NeedsHuman to true.\n\nRules:\n- Always return valid JSON.\n- Do not use markdown.\n- Do not write anything outside the JSON.\n- Do not invent information.\n- Use only the uploaded FAQ knowledge base for normal FAQ/product answers.\n- If the answer is not found in the FAQ knowledge base, say: \"I don't have enough information in my uploaded FAQ knowledge base to answer that.\"\n- Do not give medical diagnosis.\n- Do not recommend medicine or treatment.\n- If the user asks about personal order tracking, delivery status, payment, or private account details, say this demo agent does not have access to real customer orders.\n\nCustomer Name:\n{{ $json.CustomerName }}\n\nCustomer Message:\n{{ $json.Message }}\n\nReturn this exact JSON structure:\n\n{\n  \"CustomerName\": \"\",\n  \"Message\": \"\",\n  \"Category\": \"\",\n  \"Sentiment\": \"\",\n  \"Priority\": \"\",\n  \"AIReply\": \"\",\n  \"NeedsHuman\": false,\n  \"SourceUsed\": \"\"\n}\n\nAllowed categories:\n- Where To Buy\n- Product Authenticity\n- Coupons / Samples\n- Product Information\n- Ingredient / Technology Question\n- Medical Concern\n- Order / Account Question\n- General Inquiry\n\nAllowed sentiment:\n- Positive\n- Neutral\n- Negative\n\nAllowed priority:\n- Low\n- Medium\n- High\n\nFor medical or serious skin concern messages:\n- Category must be \"Medical Concern\"\n- Sentiment must be \"Negative\"\n- Priority must be \"High\"\n- NeedsHuman must be true\n- SourceUsed must be \"Safety Rule\"\n\nFor normal FAQ/product answers:\n- NeedsHuman should usually be false\n- SourceUsed must be \"CeraVe FAQ Knowledge Base\"",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -832,
        272
      ],
