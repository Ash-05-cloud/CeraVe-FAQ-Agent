    {
      "parameters": {
        "jsCode": "let output = $json.output || $json.text || $json.response || \"\";\n\nif (typeof output !== \"string\") {\n  output = JSON.stringify(output);\n}\n\nconst match = output.match(/\\{[\\s\\S]*\\}/);\n\nif (!match) {\n  throw new Error(\"No valid JSON found in AI Agent output: \" + output);\n}\n\nlet data;\n\ntry {\n  data = JSON.parse(match[0]);\n} catch (error) {\n  throw new Error(\"Failed to parse AI JSON: \" + error.message + \"\\nOutput was: \" + output);\n}\n\nreturn [\n  {\n    json: {\n      success: true,\n      CustomerName: data.CustomerName || \"Customer\",\n      Message: data.Message || \"\",\n      Category: data.Category || \"General Inquiry\",\n      Sentiment: data.Sentiment || \"Neutral\",\n      Priority: data.Priority || \"Low\",\n      AIReply: data.AIReply || \"I don't have enough information in my uploaded FAQ knowledge base to answer that.\",\n    NeedsHuman: data.NeedsHuman === true || data.NeedsHuman === \"true\",\nStatus: (data.NeedsHuman === true || data.NeedsHuman === \"true\") ? \"Needs Human\" : \"Answered\",\nSourceUsed: data.SourceUsed || \"CeraVe FAQ Knowledge Base\",\nCreatedAt: new Date().toISOString()\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -480,
        272
      ],
      "id": "104b7410-5de8-4681-9b56-e5f7127e33d6",
      "name": "Parse AI Output"
